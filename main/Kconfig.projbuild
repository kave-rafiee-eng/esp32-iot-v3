menu "Example Configuration"

    config BROKER_URL_RAVIS
        string "Broker URL"
        default "mqtt://109.125.149.108:1883"
        help
            URL of the broker to connect to

    config BROKER_URL_FROM_STDIN
        bool
        default y if BROKER_URL = "FROM_STDIN"

    config PCG_UART_TX_PIN
        int "PCG UART TX GPIO"
        default 17
        help
            GPIO number for UART2 TX used by pcgtask.

    config PCG_UART_RX_PIN
        int "PCG UART RX GPIO"
        default 16
        help
            GPIO number for UART2 RX used by pcgtask.

    config GPIO_OUTPUT_PIN
        int "RS485 DE/RE GPIO (UART RTS)"
        default 4
        help
            GPIO number connected to RS485 transceiver DE/~RE pin.
            Used as UART RTS in half-duplex RS485 mode.

    config PCG_NETWORK_MONITOR_INTERVAL_MS
        int "Network status monitor interval (ms)"
        default 1000
        range 100 60000
        help
            How often the network monitor task polls WiFi/MQTT status.

endmenu
